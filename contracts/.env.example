# contracts/.env.example
#
# Quick start:
#   cp .env.example .env
#   # editá .env con tus valores
#   source .env
#   forge script script/Deploy.s.sol --rpc-url $ALCHEMY_RPC_URL ...
#
# .env queda gitignored por el .gitignore del root del repo.
# La passphrase del keystore addie-treasury NO va acá — la pide forge interactivo.

# ─── Base mainnet RPC (P0-13) ─────────────────────────────────────────
# Misma URL que apps/web/.env.local. Si lo bajás de Vercel:
#   cd apps/web && vercel env pull .env.local && grep ^ALCHEMY .env.local
ALCHEMY_RPC_URL=""

# ─── Deploy / owner del AddieEscrow ───────────────────────────────────
# Address de la treasury wallet (la que recibió ~$5 ETH en P0-21).
# Es msg.sender del deploy + owner immutable del escrow.
# Para sacarlo del keystore:
#   cast wallet address --account addie-treasury
PLATFORM_OWNER_ADDRESS=""

# ─── Basescan / Etherscan V2 (verify) ─────────────────────────────────
# Una sola key de etherscan.io/myapikey sirve para Base (chain 8453) +
# todos los chains soportados por Etherscan API V2.
BASESCAN_API_KEY=""
