{
  "name": "addie-pipeline-poc",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "POC of the Addie streaming pipeline: OBS → nginx-rtmp → webhooks → ContextTick stream printed to terminal.",
  "scripts": {
    "demo": "tsx watch src/index.ts",
    "rtmp:up": "docker compose up -d",
    "rtmp:down": "docker compose down",
    "rtmp:logs": "docker compose logs -f rtmp",
    "smoke": "tsx scripts/smoke.ts",
    "smoke:summary": "tsx scripts/smoke-summary.ts",
    "smoke:clip": "tsx scripts/smoke-clip.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.71",
    "@elevenlabs/elevenlabs-js": "^2.46.0",
    "@supabase/supabase-js": "^2.105.4",
    "@vercel/blob": "^2.3.3",
    "ai": "^6.0.177",
    "chalk": "^5.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "tmi.js": "^1.8.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/tmi.js": "^1.8.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
