# Express webhook server port (donde llegan los hooks de nginx-rtmp).
PIPELINE_PORT=3000

# Optional: ElevenLabs Scribe v2 realtime para transcripción de audio en streaming.
# Misma API key que se usa para Creative (pre-gen de ads) y TTS — UNA sola cuenta
# cubre los 3 servicios (creá la cuenta en https://elevenlabs.io).
# Si está vacía, el POC corre sin audio_30s — frame y chat son independientes.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
ELEVENLABS_STT_LANGUAGE=es

# Ventana móvil para el campo audio_30s en cada ContextTick (ms).
AUDIO_ROLLING_WINDOW_MS=30000

# Optional: Gemini para frame analysis (B-05, próximo commit).
GEMINI_API_KEY=

# Optional: Twitch chat (B-06, próximo commit).
TWITCH_CHANNEL=
TWITCH_USERNAME=
TWITCH_OAUTH=

# Polling interval del orchestrator a /stat de nginx-rtmp.
STAT_POLL_MS=1000
