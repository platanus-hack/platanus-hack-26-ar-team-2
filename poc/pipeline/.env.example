# Express webhook server port (donde llegan los hooks de nginx-rtmp).
PIPELINE_PORT=3000

# Optional: ElevenLabs Scribe v2 realtime para transcripción de audio en streaming.
# Misma API key que se usa para Creative (pre-gen de ads) y TTS — UNA sola cuenta
# cubre los 3 servicios (creá la cuenta en https://elevenlabs.io).
# Si está vacía, el POC corre sin audio_30s — frame y chat son independientes.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
# Idioma — solo ISO-639-1 (2 chars) o ISO-639-3 (3 chars). NO acepta es-AR ni
# variantes regionales. "es" cubre todo el español incluido voseo rioplatense.
ELEVENLABS_STT_LANGUAGE=es
# Keyterms (coma-separadas, max 50, cada una max 20 chars) — sesgan al modelo
# para reconocer slang argentino y nombres propios. Vacío para no enviarlas.
# Ejemplo: ELEVENLABS_STT_KEYTERMS=che,boludo,groso,Coscu,Davoo,Wakra,quilombo,laburo,guita,chamuyo
ELEVENLABS_STT_KEYTERMS=

# Ventana móvil para el campo audio_30s en cada ContextTick (ms).
AUDIO_ROLLING_WINDOW_MS=30000

# Frame analysis (B-05) usa Vercel AI Gateway con Gemini 2.5 Flash multimodal.
# Una sola key del gateway rutea a Gemini/Claude/GPT/etc — no necesitamos
# GEMINI_API_KEY directa. Sacá la key en https://vercel.com/dashboard → AI Gateway.
# Sin esta key, el POC corre sin frame analysis (audio y chat son independientes).
AI_GATEWAY_API_KEY=
FRAME_MODEL=google/gemini-2.5-flash
# Frames por segundo capturados del stream para análisis. 1 = 1 frame/seg.
FRAME_FPS=1

# Twitch Helix API para metrics del stream (viewers, game_category, title).
# Las creds son del PROYECTO Addie (NO per-creator), shared. Una app dummy en
# https://dev.twitch.tv/console/apps autentica las consultas Helix de todos
# los creators que tengamos. Gratis, rate limit 800/min, Client Credentials grant.
# Sin esto los campos viewers/game/title quedan NULL, el resto sigue funcionando.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_POLL_MS=30000

# El canal Twitch de cada stream se decide PER-SESSION:
#   - En producción (apps/web): el handler del on_publish lookups por stream_key
#     en `accounts.metadata.twitch_channel` y pasa el valor a startSession({ twitchChannel }).
#   - En POC standalone: por default se usa el stream_key del nginx-rtmp como
#     twitch_channel (asume que el creator usa su username Twitch como stream_key).
#   - Override global SOLO para testing (forzar TODAS las sesiones al mismo canal,
#     útil para apuntar a un streamer popular y ver chat/viewers reales):
# TWITCH_CHANNEL_OVERRIDE=

# El chat tmi.js NO requiere auth (anonymous read-only), reusa el twitchChannel
# resuelto arriba. No hace falta registrar app aparte para chat.

# Persistencia: Supabase para guardar context_chunks consolidados cada N segundos.
# Sin estas vars el chunk writer loggea a consola en lugar de hacer INSERT.
# El service role key bypassea RLS — server-side ONLY, NO commitear, NO frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CHUNK_INTERVAL_MS=30000

# Polling interval del orchestrator a /stat de nginx-rtmp.
STAT_POLL_MS=1000
