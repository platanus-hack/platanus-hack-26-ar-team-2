# Express webhook server port (donde llegan los hooks de nginx-rtmp).
PIPELINE_PORT=3000

# Optional: ElevenLabs Scribe v2 realtime para transcripción de audio en streaming.
# Misma API key que se usa para Creative (pre-gen de ads) y TTS — UNA sola cuenta
# cubre los 3 servicios (creá la cuenta en https://elevenlabs.io).
# Si está vacía, el POC corre sin audio_30s — frame y chat son independientes.
ELEVENLABS_API_KEY=
ELEVENLABS_STT_MODEL=scribe_v2_realtime
# Idioma — solo ISO-639-1 (2 chars) o ISO-639-3 (3 chars). NO acepta es-AR ni
# variantes regionales. "es" cubre todo el español incluido voseo rioplatense.
ELEVENLABS_STT_LANGUAGE=es
# Keyterms (coma-separadas, max 50, cada una max 20 chars) — sesgan al modelo
# para reconocer slang argentino y nombres propios. Vacío para no enviarlas.
# Ejemplo: ELEVENLABS_STT_KEYTERMS=che,boludo,groso,quilombo,laburo,guita,chamuyo,addie
ELEVENLABS_STT_KEYTERMS=

# Ventana móvil del transcript de audio. Default 15s (bajado desde 30s el
# 2026-05-09 para matchear CHUNK_INTERVAL_MS). Si lo cambiás, mantenelo igual
# a CHUNK_INTERVAL_MS para evitar overlap o pérdida de audio entre chunks.
AUDIO_ROLLING_WINDOW_MS=15000

# Modelos Claude (frame analysis B-05 + audio summary B-07c).
#
# Tenemos DOS rutas posibles para hablar con Claude:
#
# 1) ANTHROPIC_API_KEY (preferida) — provider directo de Anthropic. Es la
#    misma key que ya usa apps/web (P0-07) — UNA key cubre todos los agents
#    + el pipeline POC. Sacala en https://console.anthropic.com/. Tier 1
#    arranca en 50 RPM (suficiente para CHUNK=15s + FRAME_FPS=0.5); subir a
#    tier 2 levanta a 1000 RPM si querés más resolución temporal.
#
# 2) AI_GATEWAY_API_KEY — Vercel AI Gateway. Rutea a Anthropic/Google/GPT
#    con una sola key, útil si querés cambiar de provider sin redeploy. Su
#    free tier está rate-limiteado pesado por abuso (mayo 2026); si pagás
#    credits funciona perfecto. Sacala en https://vercel.com/dashboard →
#    AI Gateway.
#
# El código usa ANTHROPIC_API_KEY si está seteada (provider directo,
# `@ai-sdk/anthropic`). Si no, cae a AI_GATEWAY_API_KEY (modelo como string).
# Si no está NINGUNA, frame y audio summary quedan disabled, audio + chat
# siguen funcionando.
ANTHROPIC_API_KEY=
AI_GATEWAY_API_KEY=

# Modelo para frame analysis. Default Haiku 4.5 porque frame es N/seg → la
# diferencia de costo vs Sonnet importa. Haiku 4.5 soporta vision y es
# suficiente para describir escenas de stream. Si querés más calidad visual,
# subí a claude-sonnet-4-5 (más caro, mismo schema). Si usás AI Gateway,
# prefijá con "anthropic/" (ej "anthropic/claude-sonnet-4-5").
FRAME_MODEL=claude-haiku-4-5
# Frames por segundo capturados del stream. 0.5 = 1 frame cada 2 segundos.
# El trade-off es costo + rate limit del provider. Con Anthropic tier 1
# (50 RPM) y CHUNK=15s + FRAME_FPS=0.5 + audio summary, estás en ~16-19 RPM
# y queda holgado. Subí a 1 si tenés tier 2+ y querés más resolución
# temporal — la escena visual de un stream cambia despacio así que ganar
# perdés poca info quedándote en 0.5.
FRAME_FPS=0.5

# Modelo para audio summary (cada chunk, en chunkWriter). Mismo provider que
# frame, model independiente para tunear costo/calidad por separado.
AUDIO_SUMMARY_MODEL=claude-haiku-4-5

# Twitch Helix API para metrics del stream (viewers, game_category, title).
# Las creds son del PROYECTO Addie (NO per-creator), shared. Una app dummy en
# https://dev.twitch.tv/console/apps autentica las consultas Helix de todos
# los creators que tengamos. Gratis, rate limit 800/min, Client Credentials grant.
# Sin esto los campos viewers/game/title quedan NULL, el resto sigue funcionando.
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_POLL_MS=30000

# El canal Twitch de cada stream se decide PER-SESSION:
#   - En producción (apps/web): el handler del on_publish lookups por stream_key
#     en `accounts.metadata.twitch_channel` y pasa el valor a startSession({ twitchChannel }).
#   - En POC standalone: por default se usa el stream_key del nginx-rtmp como
#     twitch_channel (asume que el creator usa su username Twitch como stream_key).
#   - Override global SOLO para testing (forzar TODAS las sesiones al mismo canal,
#     útil para apuntar a un streamer popular y ver chat/viewers reales):
# TWITCH_CHANNEL_OVERRIDE=

# El chat tmi.js NO requiere auth (anonymous read-only), reusa el twitchChannel
# resuelto arriba. No hace falta registrar app aparte para chat.

# Persistencia: Supabase para guardar context_chunks consolidados cada N segundos.
# Sin estas vars el chunk writer loggea a consola en lugar de hacer INSERT.
# El service role key bypassea RLS — server-side ONLY, NO commitear, NO frontend.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Default 15s (bajado desde 30s el 2026-05-09). El manager-worker (Track C)
# decide placements 1× por chunk → menor intervalo = más placements/min posibles.
# Heads up rate limits Anthropic tier 1 (50 RPM): con CHUNK=15s + FRAME_FPS=0.5
# estás en ~16-19 RPM, holgado. Si chocás 429 (raro en tier 1+), bajá FRAME_FPS
# a 0.33 o subí de tier en console.anthropic.com.
CHUNK_INTERVAL_MS=15000

# Polling interval del orchestrator a /stat de nginx-rtmp.
STAT_POLL_MS=1000

# Audit clip (B-08 + B-11). Recorder ffmpeg long-lived que mantiene los últimos
# ~20s del stream en disco como segmentos rotativos. Cuando llega POST
# /api/audit/clip, concatenamos los más recientes y subimos a Vercel Blob.
#
# BLOB_READ_WRITE_TOKEN — REQUIRED · P0-14 · Andy.
# Token de Vercel Blob. Sin esta token, el endpoint POST /api/audit/clip
# devuelve HTTP 503 con `{ code: 'BLOB_TOKEN_MISSING' }`. NO HAY FALLBACK
# LOCAL — la decisión es "audit clip o nada" porque la marca necesita una
# URL pública para consumir el clip; un `file://` no le sirve.
#
# Cómo conseguirla:
#   Vercel Dashboard → Storage → Blob → crear store si no existe → token.
BLOB_READ_WRITE_TOKEN=

# Tuneables del recorder (defaults razonables). 4 × 5s = 20s de buffer.
# Subí RECORDER_SEGMENT_COUNT a 6 si querés clips más largos (hasta 30s).
RECORDER_SEGMENT_TIME_S=5
RECORDER_SEGMENT_COUNT=4
RECORDER_DIR=/tmp/addie-record

# Duración default del audit clip (override por request con `duration_s`).
# Directorio temporal para concat antes de subir a Blob (se limpia automático).
AUDIT_CLIP_DURATION_S=10
AUDIT_CLIP_TEMP_DIR=/tmp/addie-clips
