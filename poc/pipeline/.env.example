# Express webhook server port (donde llegan los hooks de nginx-rtmp).
PIPELINE_PORT=3000

# Optional: Deepgram para transcript real (sin esto el POC mockea audio).
DEEPGRAM_API_KEY=

# Optional: Gemini para frame analysis real (sin esto el POC mockea frames).
GEMINI_API_KEY=

# Optional: Twitch chat real (sin esto el POC mockea chat).
TWITCH_CHANNEL=
TWITCH_USERNAME=
TWITCH_OAUTH=

# Verbosity / UI
ADDIE_TYPEWRITER_MS=8
