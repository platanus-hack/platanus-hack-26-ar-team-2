# apps/web/.env.example
#
# Quick start (recommended):
#   cd apps/web && vercel env pull .env.local
# This populates the FULL set of vars below from the Vercel project
# (arvenz0210s-projects/web), which is auto-injected by the Vercel ↔ Supabase
# integration. No manual copy-pasting.
#
# What's where:
#   - PUBLIC keys (URL + anon)   → already hardcoded in src/lib/supabase.ts
#   - SECRET keys (service_role, JWT secret, postgres password)
#                                → loaded from process.env at runtime,
#                                  Vercel deploys read them from the project's
#                                  encrypted env, local dev reads from
#                                  apps/web/.env.local (gitignored).

# ─── Supabase (auto-injected by Vercel integration) ────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://yktmoorpmlvnzfthmrlq.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""

# Bypasses RLS — DO NOT log, NEVER ship to client bundle.
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_JWT_SECRET=""
SUPABASE_SECRET_KEY=""

# Direct Postgres (used by scripts/db-migrate.mjs and any pg.Client)
POSTGRES_URL=""
POSTGRES_URL_NON_POOLING=""
POSTGRES_PASSWORD=""

# ─── Other services (claim the relevant P0 task to provision) ──────────
# ANTHROPIC_API_KEY=""           # P0-07 — Claude 4.6 Sonnet (brand + streamer agents)
# GEMINI_API_KEY=""              # P0-08 — Gemini 2.5 Flash (vision pipe, frames @1fps)
# ELEVENLABS_API_KEY=""          # P0-10 — Scribe v2 STT realtime + TTS + Creative pre-gen
# PRIVY_APP_ID=""                # P0-11 — Privy app ID (public, safe in client)
# NEXT_PUBLIC_PRIVY_APP_ID=""    # P0-11 — same value, exposed to browser via NEXT_PUBLIC_
# PRIVY_APP_SECRET=""            # P0-11 — server-only, never ship to client bundle
# ALCHEMY_RPC_URL=""             # P0-13 — Base mainnet RPC (already provisioned ✅)
CHAIN_LIVE_TXS="false"           # A-12 kill-switch — set to "true" only in F-05 to allow on-chain writes (lock/release/refund). Default false blocks broadcast in dev/QA.
# BLOB_READ_WRITE_TOKEN=""       # P0-14 — Vercel Blob (ad assets + audit clips)
# TWITCH_CHANNEL=""              # P0-15 — Twitch channel name for tmi.js (e.g. "team-stream")
# TWITCH_USERNAME=""             # P0-15 — bot username for chat connection
# TWITCH_OAUTH_TOKEN=""          # P0-15 — oauth:xxxx token, get from twitchapps.com/tmi
