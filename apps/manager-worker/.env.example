# Supabase (lo que el worker usa para Realtime + lookups)
SUPABASE_URL=https://<project>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Anthropic (Claude Haiku 4.5). MANAGER_DRY_RUN=true lo hace opcional.
ANTHROPIC_API_KEY=sk-ant-...

# Render endpoint del Next.js (donde POSTeamos cuando hay match)
ADDIE_API_BASE_URL=https://<vercel-deploy-or-localhost-3000>

# Stream a vigilar (filter del Realtime + path del POST). MVP: hardcoded.
MANAGER_STREAM_KEY=coscu-test

# Filtro Stage 2 (Claude). Permisivo para primer smoke; tighten en rehearsal.
MANAGER_MOMENT_QUALITY_MIN=0.5
MANAGER_BRAND_MATCH_MIN=0.55
MANAGER_COOLDOWN_S=30

# Si true: skip Claude, devuelve un pick stub. Útil para smoke sin API key.
MANAGER_DRY_RUN=false

# Modelo. Por default Haiku 4.5; podés cambiar a Sonnet 4.6 para validar prompts.
ANTHROPIC_MODEL=claude-haiku-4-5
